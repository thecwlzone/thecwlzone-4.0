{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "thecwlzone",
  "type": "module",
  "version": "3.4.0",
  "description": "The Official CWL Zone Web Site",
  "author": "thecwlzone",
  "license": "CC-BY-4.0",
  "homepage": "https://github.com/thecwlzone/thecwlzone-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thecwlzone/thecwlzone-4.0.git"
  },
  "bugs": {
    "url": "https://github.com/thecwlzone/thecwlzone-4.0.git"
  },
  "keywords": [
    "astro",
    "blog",
    "template",
    "theme",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "astro dev",
