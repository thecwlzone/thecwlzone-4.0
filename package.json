    "@expressive-code/plugin-line-numbers": "^0.43.1",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@iconify-json/tabler": "^1.2.35",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
